{
  "title": "bahn.de Web API",
  "description": "Calls bahn.de web API endpoints (orte or fahrplan). Dataset rows mirror upstream JSON. See openapi/bahn-web-api.openapi.json.",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "endpoint": {
      "title": "Endpoint",
      "type": "string",
      "description": "Which bahn.de API to call",
      "enum": ["orte", "fahrplan"],
      "enumTitles": ["Station search (GET /reiseloesung/orte)", "Connections (POST /angebote/fahrplan)"],
      "default": "fahrplan"
    },
    "query": {
      "title": "Suchbegriff (orte)",
      "type": "string",
      "description": "Required for endpoint=orte",
      "editor": "textfield",
      "prefill": "Berlin Hbf"
    },
    "stationType": {
      "title": "Ort-Typ (orte)",
      "type": "string",
      "enum": ["ALL", "BAHNHOF", "ORT", "POI"],
      "default": "ALL"
    },
    "limit": {
      "title": "Limit (orte)",
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 5
    },
    "origin": {
      "title": "Startbahnhof (fahrplan)",
      "type": "string",
      "editor": "textfield",
      "prefill": "Berlin Hbf"
    },
    "destination": {
      "title": "Zielbahnhof (fahrplan)",
      "type": "string",
      "editor": "textfield",
      "prefill": "München Hbf"
    },
    "departureDateTime": {
      "title": "Abfahrt (ISO)",
      "type": "string",
      "description": "e.g. 2026-06-01T08:00:00 — or use travelDate + departureHour",
      "editor": "textfield",
      "prefill": "2026-06-01T08:00:00"
    },
    "travelDate": {
      "title": "Reisedatum (fahrplan)",
      "type": "string",
      "description": "YYYY-MM-DD if departureDateTime omitted",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "departureHour": {
      "title": "Abfahrt Stunde",
      "type": "integer",
      "minimum": 0,
      "maximum": 23,
      "default": 8
    },
    "departureMinute": {
      "title": "Abfahrt Minute",
      "type": "integer",
      "minimum": 0,
      "maximum": 59,
      "default": 0
    },
    "travelClass": {
      "title": "Reiseklasse",
      "type": "integer",
      "enum": [1, 2],
      "default": 2
    },
    "passengerAge": {
      "title": "Passagieralter",
      "type": "integer",
      "minimum": 0,
      "maximum": 120
    },
    "bahnCard": {
      "title": "BahnCard",
      "type": "string",
      "enum": ["none", "25", "50", "100"],
      "default": "none"
    },
    "hasDeutschlandTicket": {
      "title": "Deutschland-Ticket",
      "type": "boolean",
      "default": false
    },
    "deutschlandTicketOnly": {
      "title": "Nur Deutschland-Ticket-Verbindungen",
      "type": "boolean",
      "default": false
    },
    "maxTransfers": {
      "title": "Max. Umstiege",
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "default": 5
    },
    "proxyConfiguration": {
      "title": "Proxy",
      "type": "object",
      "editor": "proxy",
      "prefill": {
        "useApifyProxy": true,
        "apifyProxyGroups": ["RESIDENTIAL"],
        "apifyProxyCountry": "DE"
      }
    }
  },
  "required": ["endpoint"]
}
